# ─────────────────────────────────────────────────────────────────────────────
#  SMA Outfit Engine — environment variables
# ─────────────────────────────────────────────────────────────────────────────
#
#  Copy this file to .env and fill in your own values:
#
#      cp .env.example .env
#
#  Then edit .env with your actual Webull credentials. The .env file is
#  gitignored, so it will never be committed to version control.
#
# ─────────────────────────────────────────────────────────────────────────────


# ─── Data source ─────────────────────────────────────────────────────────────
# Set to "mock" to run with synthetic data (no credentials required, useful
# for verifying the engine works before you have Webull access).
# Set to "webull" to use real Webull OpenAPI data (requires credentials below).
ENGINE_SOURCE=mock


# ─── Webull OpenAPI credentials ──────────────────────────────────────────────
# Apply at https://developer.webull.com/ — individual developer account.
# Approval takes 1-2 business days. Request MARKET DATA permissions only;
# do NOT request trading permissions if you only want signal detection.
#
# Once approved, generate app_key and app_secret in the Webull developer
# portal and paste them here.

WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_REGION=us


# ─── Universe to scan ────────────────────────────────────────────────────────
# tier1  = 143 ETFs — all major indices, leveraged pairs, sectors, vol (streaming tier)
# tier2  = tier1 + mega-cap individual stocks (~183 tickers)
# all    = tier1 + tier2 + extended individual equities (~1,705 unique tickers)

ENGINE_UNIVERSE=tier1


# ─── Scan interval ───────────────────────────────────────────────────────────
# How often the engine re-scans, in seconds. 300 = every 5 minutes.
# With the full universe, cycles take 25-40 min so the engine runs back-to-back.

ENGINE_INTERVAL_SECONDS=300

# Number of ranked combinations written to output each cycle.
ENGINE_TOP_N=500


# ─── Timeframes ──────────────────────────────────────────────────────────────
# Comma-separated list of timeframes to scan. Available:
#   1m, 5m, 15m, 30m, 1h, 2h, 4h, 1d, 1w, 1mo

ENGINE_TIMEFRAMES=5m,15m,30m,1h,1d


# ─── Incremental fetch ───────────────────────────────────────────────────────
# On cycle 2+, only this many recent bars are fetched per (ticker, timeframe)
# pair and merged into the cache. Set to 0 to always fetch full history.

ENGINE_REFRESH_BARS=20


# ─── Lookback ────────────────────────────────────────────────────────────────
# Number of recent candles to score when ranking hits. Max 999.
# 130 = ~10 days on 30m, ~6 months on 1d.

ENGINE_LOOKBACK=130


# ─── Hit detection mode ──────────────────────────────────────────────────────
# exact  — SMA must equal O/H/L/C at 2 decimal places. Most precise (default).
# wick   — SMA within candle's [low, high] range or within HIT_TOLERANCE of O/C.
# both   — runs both checks. Maximum sensitivity.

HIT_MODE=exact

# Dollar tolerance for open/close proximity in wick/both modes. 0.0 = disabled.
HIT_TOLERANCE=0.0


# ─── Microterm filter ────────────────────────────────────────────────────────
# Minimum timeframe (minutes) for a signal to appear in rankings.
# 0 = no filter. 15 = exclude 1m and 5m (recommended). 60 = 1h+ only.

ENGINE_MIN_TF_MINUTES=15


# ─── Sub-minute streaming ────────────────────────────────────────────────────
# Set STREAM_ENABLED=true to receive real-time tick data via Webull MQTT.
# Ticks are aggregated into sub-minute candles and scanned each cycle.
# Requires streaming permissions on your Webull developer account.

STREAM_ENABLED=false
STREAM_TIMEFRAMES=1s,5s,15s,30s
STREAM_HOST=wss.webullfintech.com
WEBULL_API_HOST=api.webullfintech.com


# ─── Regime refit cadence ────────────────────────────────────────────────────
# Refit the HMM regime model every N cycles.
# At 300s intervals: 12 = every 60 minutes.

ENGINE_REGIME_EVERY=12


# ─── InfluxDB (do not change unless you know what you're doing) ──────────────

INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=element47-dev-token
INFLUX_ORG=element47
INFLUX_BUCKET=sma_engine


# ─── Output: local files + optional Google Sheets ────────────────────────────
# The engine always writes local files (signals_current.xlsx + signals_log.csv)
# to the directory below. Open them in Excel, Numbers, or any spreadsheet app.

LOCAL_OUTPUT_DIR=./output

# Terminal UI: shows a live-updating dashboard in your terminal while the
# engine runs. Set to false when running headless or over SSH.
TERMINAL_UI=true

# Google Sheets — completely optional. Lets you view the engine output on
# your phone via the Google Sheets app. Setup is 6 steps documented in the
# README. If you skip it, local files still work.
#
# To enable:
#   1. Set GOOGLE_SHEETS_CREDENTIALS_PATH to your service account JSON
#   2. Set GOOGLE_SHEET_ID to the Sheet ID from your Google Sheets URL
#      (the long string after /d/ in the URL)

GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEET_ID=
